<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_debt_interest" model="ir.cron">
            <field name="name">Debt: Calculate Interest</field>
            <field name="model_id" ref="model_debt_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_calculate_interest()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="active">True</field>
        </record>

        <record id="ir_cron_debt_overdue_notify" model="ir.cron">
            <field name="name">Debt: Check Overdue &amp; Send Reminders</field>
            <field name="model_id" ref="model_debt_record"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_overdue_and_notify()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>

            <field name="active">True</field>
        </record>
    </data>
</odoo>
