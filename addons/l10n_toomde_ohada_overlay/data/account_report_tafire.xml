<?xml version="1.0" encoding="utf-8"?>
<!--
  TAFIRE — Tableau Financier des Ressources et Emplois (Acte Uniforme
  révisé 2018, article 26-3). Mandatory annual report alongside Bilan
  and Compte de résultat for Système Normal filers.

  OHADA structure splits movements into:

    EMPLOIS (uses of funds)
      - Investissements (immobilisations acquired during the year)
      - Charges immobilisées
      - Remboursement de dettes financières
      - Variation BFR exploitation (if BFR up)
      - Variation BFR HAO (if up)

    RESSOURCES (sources of funds)
      - CAF (Capacité d'Autofinancement) = Résultat net + dot. amort
      - Cessions d'immobilisations (Class 82)
      - Augmentation de capital (Class 10 var. positive)
      - Emprunts nouveaux (Class 16 var. positive)
      - Subventions d'investissement (Class 14)

    VARIATION DE TRÉSORERIE = Ressources - Emplois

  The TAFIRE in its filing form is a movement statement — it shows
  changes between N-1 and N, not balances. Odoo's `account.report` is
  balance-oriented; surfacing movements properly needs a custom
  computation. We render the structure here with current-year balances
  on each line so the user has the layout; full movement math
  (`balance N - balance N-1`) is in the Python expression engine,
  computed by `_class_totals` style helpers in dsf_export.py.

  Reference: OHADA AUDCIF article 27, Annexe (TAFIRE — Tableau N°4).
-->
<odoo>

  <record id="syscohada_tafire_report" model="account.report">
    <field name="name">TAFIRE — Tableau Financier des Ressources et Emplois</field>
    <field name="filter_period_comparison" eval="True"/>
    <field name="filter_unfold_all" eval="True"/>
    <field name="column_ids">
      <field name="name">Exercice N</field>
      <field name="expression_label">balance</field>
    </field>

    <field name="line_ids">

      <!-- ============================================================
           EMPLOIS (uses of funds during the year)
           ============================================================ -->
      <record id="syscohada_tafire_emplois_header" model="account.report.line">
        <field name="name">EMPLOIS</field>
        <field name="hierarchy_level">0</field>
      </record>

      <record id="syscohada_tafire_FA" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FA — Charges immobilisées (acquisitions)</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FA</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '20%')]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_FB" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FB — Immobilisations incorporelles</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FB</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '21%')]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_FC" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FC — Immobilisations corporelles</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FC</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('22', '23', '24'))]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_FD" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FD — Immobilisations financières</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FD</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('26', '27'))]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_FE" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FE — Remboursement des dettes financières</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FE</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '16%')]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_FF" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_emplois_header"/>
        <field name="name">FF — Variation du BFR d'exploitation (augmentation)</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_FF</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('3', '40', '41'))]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <!-- ============================================================
           RESSOURCES (sources of funds during the year)
           ============================================================ -->
      <record id="syscohada_tafire_ressources_header" model="account.report.line">
        <field name="name">RESSOURCES</field>
        <field name="hierarchy_level">0</field>
      </record>

      <record id="syscohada_tafire_GA" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_ressources_header"/>
        <field name="name">GA — Capacité d'Autofinancement Globale (CAFG)</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_GA</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('13', '68'))]</field>
          <field name="subformula">-sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_GB" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_ressources_header"/>
        <field name="name">GB — Cessions d'immobilisations</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_GB</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('82', '822'))]</field>
          <field name="subformula">-sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_GC" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_ressources_header"/>
        <field name="name">GC — Augmentation de capital</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_GC</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '10%')]</field>
          <field name="subformula">-sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_GD" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_ressources_header"/>
        <field name="name">GD — Subventions d'investissement reçues</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_GD</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '14%')]</field>
          <field name="subformula">-sum</field>
        </field>
      </record>

      <record id="syscohada_tafire_GE" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_ressources_header"/>
        <field name="name">GE — Emprunts nouveaux et dettes financières</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_GE</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', 'in', ('16', '17'))]</field>
          <field name="subformula">-sum</field>
        </field>
      </record>

      <!-- ============================================================
           VARIATION DE TRÉSORERIE
           ============================================================ -->
      <record id="syscohada_tafire_var_header" model="account.report.line">
        <field name="name">VARIATION DE TRÉSORERIE</field>
        <field name="hierarchy_level">0</field>
      </record>

      <record id="syscohada_tafire_HA" model="account.report.line">
        <field name="parent_id" ref="syscohada_tafire_var_header"/>
        <field name="name">HA — Trésorerie nette à la clôture</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_TAF_HA</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '5%')]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

    </field>
  </record>
</odoo>
