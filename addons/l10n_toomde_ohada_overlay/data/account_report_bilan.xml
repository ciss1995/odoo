<?xml version="1.0" encoding="utf-8"?>
<!--
  Bilan SYSCOHADA — Système Normal (Acte Uniforme révisé 2018).

  This is the official line structure with the AUDCIF code letters
  (AD, AE, … BZ for ACTIF; CA, … DZ for PASSIF). Each code maps to one
  or more SYSCOHADA account ranges (Class 1-5). Codes here are the same
  ones an OHADA auditor expects to see in the leftmost column of the
  filing — the wire format for Form 1004 and country-specific DSF.

  Reference: OHADA AUDCIF Acte Uniforme, articles 24-31 + Annexe
  ("Plan des Comptes — Système Normal"). Cross-checked against the
  Bilan template published by CN-OHADA-CI and DGID Sénégal.

  Layout: 4-column Brut / Amort. & Prov. / Net N / Net N-1.
  Odoo's `account.report` natively renders Net N + period comparison
  (Net N-1). Brut/Amort columns are derivable from the same lines
  (debit-side of Class 2 = Brut, amortissement accounts 28/29 = Amort);
  exposing them as separate columns is a follow-up once we have a
  reference DSF to align against.
-->
<odoo>

  <record id="syscohada_bilan_report" model="account.report">
    <field name="name">Bilan SYSCOHADA (Système Normal)</field>
    <field name="filter_period_comparison" eval="True"/>
    <field name="filter_unfold_all" eval="True"/>
    <field name="column_ids">
      <field name="name">Net N</field>
      <field name="expression_label">balance</field>
    </field>

    <field name="line_ids">

      <!-- ============================================================
           ACTIF
           ============================================================ -->
      <record id="syscohada_bilan_actif_header" model="account.report.line">
        <field name="name">ACTIF</field>
        <field name="hierarchy_level">0</field>
      </record>

      <!-- Actif immobilisé -->
      <record id="syscohada_bilan_AD" model="account.report.line">
        <field name="parent_id" ref="syscohada_bilan_actif_header"/>
        <field name="name">AD — Charges immobilisées</field>
        <field name="hierarchy_level">1</field>
        <field name="code">SC_BIL_AD</field>
        <field name="expression_ids">
          <field name="label">balance</field>
          <field name="engine">domain</field>
          <field name="formula">[('account_id.code', '=like', '20%')]</field>
          <field name="subformula">sum</field>
        </field>
      </record>

      <record id="syscohada_bilan_AE" model="account.report.line">
